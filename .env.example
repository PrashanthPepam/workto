# ─── LLM Configuration ────────────────────────────────────────────────────────

# Option 1: OpenRouter — free models available at https://openrouter.ai
OPENAI_API_KEY=dial-vee6dzuv3dtwm3iyz67fet7mzdx
OPENAI_API_URL=https://openrouter.ai/api/v1
OPENAI_MODEL=meta-llama/llama-3.1-8b-instruct:free

# Option 2: OpenAI directly
# OPENAI_API_KEY=sk-your-key-here
# OPENAI_API_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini

# Option 3: Local Ollama (must support tool calling, e.g. llama3.1)
# OPENAI_API_KEY=ollama
# OPENAI_API_URL=http://localhost:11434/v1
# OPENAI_MODEL=llama3.1

# ─── Application ──────────────────────────────────────────────────────────────

KNOWLEDGE_DIR=./knowledge
DB_PATH=./data/qna.db

# ─── Agent Behaviour ──────────────────────────────────────────────────────────

# Hard stop on runaway tool-call loops
AGENT_MAX_ITERATIONS=10

# Max KB files the agent may read in a single response (context budget)
AGENT_MAX_KB_FILES=2
